@startuml DeliveryIQ_SequenceDiagram
!theme cerulean-outline
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 220
skinparam BoxPadding 12
skinparam ParticipantPadding 20

title DeliveryIQ — Optimization Sequence Diagram

actor       "User"                  as User
participant "app.py"                as App
participant "geocoder.py"           as Geo
participant "graph_builder.py"      as GB
participant "route_solver.py"       as RS
participant "vrp_solver.py"         as VRP
participant "visualizer.py"         as Viz
participant "Nominatim / OSMnx"     as Ext

' ──────────────────────────────────────────────────────────────────────────────
== 1. Startup & Initialisation ==
' ──────────────────────────────────────────────────────────────────────────────

User  ->  App  : streamlit run app.py
App   ->  App  : _init() — populate st.session_state\n{city, depot=None, stops=[], fleet=[Vehicle], click_mode=False}
App  -->  User : Empty map + sidebar rendered

' ──────────────────────────────────────────────────────────────────────────────
== 2. Input — Depot & Delivery Stops ==
' ──────────────────────────────────────────────────────────────────────────────

User  ->  App  : Enter depot address
App   ->  Geo  : geocode("address, Dnipro, Ukraine")
Geo   ->  Ext  : Nominatim HTTP request
Ext  -->  Geo  : (lat, lon)
Geo  -->  App  : (lat, lon)
App   ->  App  : depot = DeliveryStop(address, lat, lon, source="typed")
App  -->  User : Green depot marker on map

group Add stops (repeated)
    alt Typed address
        User  ->  App : Enter delivery address
        App   ->  Geo : geocode(address + city)
        Geo   ->  Ext : Nominatim HTTP request
        Ext  -->  Geo : (lat, lon)
        Geo  -->  App : (lat, lon)
    else Map click
        User  ->  App : Click on map
        App   ->  Geo : reverse_geocode(lat, lon)
        Geo   ->  Ext : Nominatim reverse HTTP request
        Ext  -->  Geo : address string
        Geo  -->  App : address string
    end
    App  ->  App  : stops.append(DeliveryStop(...))
    App -->  User  : Numbered red marker on map
end

' ──────────────────────────────────────────────────────────────────────────────
== 3. OSM Network Download ==
' ──────────────────────────────────────────────────────────────────────────────

User  ->  App  : Click "Optimize Route"
App   ->  GB   : cached_network_at(depot.lat, depot.lon, radius)

note right of GB
  Uses depot coordinates, NOT city string.
  Avoids Nominatim misplacing city centroid.
end note

GB    ->  GB   : _configure_osmnx_tags()
GB    ->  Ext  : ox.graph_from_point(lat, lon, dist=radius, network_type="all")
Ext  -->  GB   : G_raw : MultiDiGraph
GB    ->  GB   : ox.truncate.largest_component(G_raw, strongly=True)
GB   -->  App  : G : LSCC-pruned MultiDiGraph

' ──────────────────────────────────────────────────────────────────────────────
== 4. Address Snapping ==
' ──────────────────────────────────────────────────────────────────────────────

loop for each stop (depot first, then delivery stops)
    alt source == "map_click"
        App  ->  GB : nearest_node_safe(G, lat, lon, tolerance_m=500)
        GB   ->  GB : bbox check → raise ValueError if out of bounds
    else source == "typed"
        App  ->  GB : nearest_node(G, lat, lon)
    end
    GB   ->  Ext : ox.nearest_nodes(G, X=lon, Y=lat)
    Ext -->  GB  : node_id : int
    GB  -->  App : node_id
    App  ->  App : stop.node_id = node_id
end

App  ->  App : Detect node collisions → warn user
App  ->  App : unique_nodes = deduplicated [depot_node] + [stop_nodes]

' ──────────────────────────────────────────────────────────────────────────────
== 5. Travel-Time Stamping ==
' ──────────────────────────────────────────────────────────────────────────────

App  ->  GB  : cached_mode_graphs_at(depot.lat, depot.lon, radius)
GB   ->  GB  : add_travel_times(G)

note right of GB
  Three deep copies of G.
  Each edge gets travel_time (seconds).
  Impassable edges → PENALTY = 1e9 s.
  drive: footways, motor_vehicle=no → PENALTY
  bike: steps, wrong-way one-ways → PENALTY
  walk: foot=no, access=private → PENALTY
  steps (walk): speed × 0.5
end note

GB  -->  App : {"drive": G_drive, "bike": G_bike, "walk": G_walk}

' ──────────────────────────────────────────────────────────────────────────────
== 6. Route Optimisation (TSP or VRP) ==
' ──────────────────────────────────────────────────────────────────────────────

alt Single-vehicle TSP  [run_optimization()]

    group Drive Mode — Hybrid Last-Meter
        loop for each stop
            App  ->  GB : nearest_car_accessible_node(G_drive, lat, lon)
            GB  -->  App : n_car : int
            App  ->  GB : distance_m_between_nodes(G_drive, n_ped, n_car)
            GB  -->  App : gap_m : float
            alt gap_m > 100 m
                App  ->  App : mark stop as car-unreachable
            else gap_m ≤ 100 m
                App  ->  App : walk_time_s = gap_m / walk_speed
            end
        end
        App  ->  RS : build_drive_matrix_hybrid(G_drive, depot_node, car_stops)
        RS  -->  App : (matrix, car_nodes)
    end

    group Bike & Walk Modes
        App  ->  RS : build_distance_matrix(G_bike, unique_nodes)
        RS  -->  App : bike_matrix
        App  ->  RS : build_distance_matrix(G_walk, unique_nodes)
        RS  -->  App : walk_matrix
    end

    loop for mode in [drive, bike, walk]
        App  ->  RS : audit_reachability(matrix, nodes, labels)
        RS  -->  App : [UnreachableStop, ...]
        App  ->  RS : solve_tsp(nodes, matrix, method="auto")
        note right of RS
          auto: nn (1-2 stops),
                2opt (3-20),
                genetic (21+)
        end note
        RS  -->  App : (tsp_route, total_time_s)
        App  ->  RS : reconstruct_full_route(G_mode, tsp_route)
        RS  -->  App : full_route : list[int]
        App  ->  App : results[mode] = ModeResult(...)
    end

else Multi-vehicle VRP  [run_vrp_optimization()]

    App  ->  VRP : solve_vrp(stops, depot, fleet, mode_graphs, tsp_method)

    VRP  ->  VRP : Phase 1: _assign_stops_to_modes(stops, fleet, depot, graphs)\n→ group stops by compatible vehicle modes

    loop for each mode group
        VRP  ->  RS : build_distance_matrix(G_mode, group_nodes)
        RS  -->  VRP : matrix
        VRP  ->  VRP : _genetic_algorithm(stops, vehicles, depot, matrix, ...)\n  POP=50, GEN=150, OX crossover, swap mutation\n  Fitness = A·T_total + B·K (time + vehicle count)
        VRP  ->  VRP : _build_ga_routes(pool_stops, vehicles, depot, graphs)
    end

    VRP -->  App  : (routes: list[VehicleRoute], warnings: list[str])

end

' ──────────────────────────────────────────────────────────────────────────────
== 7. Result Rendering ==
' ──────────────────────────────────────────────────────────────────────────────

App  ->  App  : session_state ← {opt_results, opt_graphs, opt_warnings}

alt TSP result
    App  ->  Viz : build_result_map(mode_graphs, results, depot, stops)
    note right of Viz
      AntPath per mode (drive/bike/walk).
      LayerControl for mode toggle.
      Depot = green home icon.
      Stops = numbered red circles.
    end note
    Viz -->  App  : folium.Map
else VRP result
    App  ->  Viz : build_vrp_result_map(mode_graphs, vrp_routes, depot)
    note right of Viz
      Coloured polyline per vehicle.
      Stop markers with vehicle assignment.
    end note
    Viz -->  App  : folium.Map
end

App  -->  User : Interactive animated map
App  -->  User : Metric cards (drive / bike / walk total time)
App  -->  User : Stop-order table per mode (from → to, distance, leg time, ETA)
App  -->  User : Warning banners (collisions, unreachable, car-inaccessible)

@enduml
