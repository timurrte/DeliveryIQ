@startuml DeliveryIQ_SequenceDiagram
!theme cerulean-outline
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 220
skinparam BoxPadding 12
skinparam ParticipantPadding 20

title Діаграма послідовності оптимізації

actor       "Користувач"                  as User
participant "app.py"                as App
participant "geocoder.py"           as Geo
participant "graph_builder.py"      as GB
participant "route_solver.py"       as RS
participant "vrp_solver.py"         as VRP
participant "visualizer.py"         as Viz
participant "Nominatim / OSMnx"     as Ext

' ──────────────────────────────────────────────────────────────────────────────
== 1. Запуск та ініціалізація ==
' ──────────────────────────────────────────────────────────────────────────────

User  ->  App  : streamlit run app.py
App   ->  App  : _init() — заповнення st.session_state\n{city, depot=None, stops=[], fleet=[Vehicle], click_mode=False}
App  -->  User : Відображення порожньої карти та бічної панелі

' ──────────────────────────────────────────────────────────────────────────────
== 2. Введення — Депо та точки доставки ==
' ──────────────────────────────────────────────────────────────────────────────

User  ->  App  : Ввести адресу депо
App   ->  Geo  : geocode("address, Dnipro, Ukraine")
Geo   ->  Ext  : Nominatim HTTP request
Ext  -->  Geo  : (lat, lon)
Geo  -->  App  : (lat, lon)
App   ->  App  : depot = DeliveryStop(address, lat, lon, source="typed")
App  -->  User : Зелений маркер депо на карті

group Додавання точок (повторювано)
    alt Введена адреса
        User  ->  App : Ввести адресу доставки
        App   ->  Geo : geocode(address + city)
        Geo   ->  Ext : Nominatim HTTP request
        Ext  -->  Geo : (lat, lon)
        Geo  -->  App : (lat, lon)
    else Клік на карті
        User  ->  App : Клік на карті
        App   ->  Geo : reverse_geocode(lat, lon)
        Geo   ->  Ext : Nominatim reverse HTTP request
        Ext  -->  Geo : address string
        Geo  -->  App : address string
    end
    App  ->  App  : stops.append(DeliveryStop(...))
    App -->  User  : Нумерований червоний маркер на карті
end

' ──────────────────────────────────────────────────────────────────────────────
== 3. Завантаження мережі OSM ==
' ──────────────────────────────────────────────────────────────────────────────

User  ->  App  : Клік на "Optimize Route"
App   ->  GB   : cached_network_at(depot.lat, depot.lon, radius)

GB    ->  GB   : _configure_osmnx_tags()
GB    ->  Ext  : ox.graph_from_point(lat, lon, dist=radius, network_type="all")
Ext  -->  GB   : G_raw : MultiDiGraph
GB    ->  GB   : ox.truncate.largest_component(G_raw, strongly=True)
GB   -->  App  : G : LSCC-pruned MultiDiGraph

' ──────────────────────────────────────────────────────────────────────────────
== 4. Прив'язка адрес до вузлів ==
' ──────────────────────────────────────────────────────────────────────────────

loop для кожної точки (спочатку депо, потім точки доставки)
    alt source == "map_click"
        App  ->  GB : nearest_node_safe(G, lat, lon, tolerance_m=500)
        GB   ->  GB : перевірка bbox → raise ValueError, якщо поза межами
    else source == "typed"
        App  ->  GB : nearest_node(G, lat, lon)
    end
    GB   ->  Ext : ox.nearest_nodes(G, X=lon, Y=lat)
    Ext -->  GB  : node_id : int
    GB  -->  App : node_id
    App  ->  App : stop.node_id = node_id
end

App  ->  App : Виявлення колізій вузлів → попередити користувача
App  ->  App : unique_nodes = дедупліковані [depot_node] + [stop_nodes]

' ──────────────────────────────────────────────────────────────────────────────
== 5. Розрахунок часових міток ==
' ──────────────────────────────────────────────────────────────────────────────

App  ->  GB  : cached_mode_graphs_at(depot.lat, depot.lon, radius)
GB   ->  GB  : add_travel_times(G)

note right of GB
  Три копії G.
  Кожне ребро отримує travel_time (секунди).
  Непрохідні ребра → PENALTY = 1e9 s.
  drive: footways, motor_vehicle=no → PENALTY
  bike: steps, односторонній рух проти напрямку → PENALTY
  walk: foot=no, access=private → PENALTY
  steps (walk): швидкість × 0.5
end note

GB  -->  App : {"drive": G_drive, "bike": G_bike, "walk": G_walk}

' ──────────────────────────────────────────────────────────────────────────────
== 6. Оптимізація маршруту (TSP або VRP) ==
' ──────────────────────────────────────────────────────────────────────────────

alt TSP для одного транспортного засобу [run_optimization()]

    group Режим Drive — Гібридна "Остання миля"
        loop для кожної точки
            App  ->  GB : nearest_car_accessible_node(G_drive, lat, lon)
            GB  -->  App : n_car : int
            App  ->  GB : distance_m_between_nodes(G_drive, n_ped, n_car)
            GB  -->  App : gap_m : float
            alt gap_m > 100 m
                App  ->  App : позначити точку як недоступну для авто
            else gap_m ≤ 100 m
                App  ->  App : walk_time_s = gap_m / walk_speed
            end
        end
        App  ->  RS : build_drive_matrix_hybrid(G_drive, depot_node, car_stops)
        RS  -->  App : (matrix, car_nodes)
    end

    group Режими Bike та Walk
        App  ->  RS : build_distance_matrix(G_bike, unique_nodes)
        RS  -->  App : bike_matrix
        App  ->  RS : build_distance_matrix(G_walk, unique_nodes)
        RS  -->  App : walk_matrix
    end

    loop для кожної моделі у [drive, bike, walk]
        App  ->  RS : audit_reachability(matrix, nodes, labels)
        RS  -->  App : [UnreachableStop, ...]
        App  ->  RS : solve_tsp(nodes, matrix, method="auto")
        note right of RS
          auto: nn (1-2 точки),
                2opt (3-20),
                genetic (21+)
        end note
        RS  -->  App : (tsp_route, total_time_s)
        App  ->  RS : reconstruct_full_route(G_mode, tsp_route)
        RS  -->  App : full_route : list[int]
        App  ->  App : results[mode] = ModeResult(...)
    end

else VRP для декількох транспортних засобів [run_vrp_optimization()]

    App  ->  VRP : solve_vrp(stops, depot, fleet, mode_graphs, tsp_method)

    VRP  ->  VRP : Фаза 1: _assign_stops_to_modes(stops, fleet, depot, graphs)\n→ групування точок за сумісними режимами ТЗ

    loop для кожної групи режимів
        VRP  ->  RS : build_distance_matrix(G_mode, group_nodes)
        RS  -->  VRP : matrix
        VRP  ->  VRP : _genetic_algorithm(stops, vehicles, depot, matrix, ...)\n  POP=50, GEN=150, OX crossover, swap mutation\n  Fitness = A·T_total + B·K (час + кількість ТЗ)
        VRP  ->  VRP : _build_ga_routes(pool_stops, vehicles, depot, graphs)
    end

    VRP -->  App  : (routes: list[VehicleRoute], warnings: list[str])

end

' ──────────────────────────────────────────────────────────────────────────────
== 7. Відображення результатів ==
' ──────────────────────────────────────────────────────────────────────────────

App  ->  App  : session_state ← {opt_results, opt_graphs, opt_warnings}

alt Результат TSP
    App  ->  Viz : build_result_map(mode_graphs, results, depot, stops)
    note right of Viz
      AntPath для кожного режиму (drive/bike/walk).
      LayerControl для перемикання режимів.
      Депо = зелена іконка.
      Точки = нумеровані червоні.
    end note
    Viz -->  App  : folium.Map
else Результат VRP
    App  ->  Viz : build_vrp_result_map(mode_graphs, vrp_routes, depot)
    note right of Viz
      Кольорова полілінія для кожного ТЗ.
      Маркери точок із призначенням ТЗ.
    end note
    Viz -->  App  : folium.Map
end

App  -->  User : Інтерактивна анімована карта
App  -->  User : Картки метрик (загальний час drive / bike / walk)
App  -->  User : Таблиця черговості точок за режимом (від → до, відстань, час етапу, ETA)
App  -->  User : Банери попереджень (колізії, недосяжність, недоступність для авто)

@enduml