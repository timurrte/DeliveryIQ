# Copy this file to .env and fill in your credentials.
# Load it before starting the app:
#   set -a && source .env && set +a   (Linux/macOS)
#   $env:MAPBOX_API_KEY="sk...."      (PowerShell)

# Mapbox access token — enables traffic-aware drive-mode routing.
# Get one at https://account.mapbox.com/access-tokens/
# Required scopes: directions:read
MAPBOX_API_KEY=
